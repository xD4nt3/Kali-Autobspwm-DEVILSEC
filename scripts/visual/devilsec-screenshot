#!/usr/bin/env bash
# DEVILSEC · screenshot helper
# Usage: devilsec-screenshot {region|window|full} [--copy]
# Saves to ~/Pictures/screenshots, names by timestamp, copies to clipboard
# unless --no-copy. Notifies via dunst.

set -uo pipefail
MODE="${1:-region}"
SHOT_DIR="$HOME/Pictures/screenshots"
mkdir -p "$SHOT_DIR"
TS=$(date +"%Y-%m-%d_%H-%M-%S")
OUT="$SHOT_DIR/devilsec_${MODE}_${TS}.png"

case "$MODE" in
    region) flameshot gui --path "$SHOT_DIR" --clipboard ;;
    window) flameshot screen --clipboard --path "$SHOT_DIR" -p "$OUT" ;;
    full)   flameshot full   --clipboard --path "$SHOT_DIR" -p "$OUT" ;;
    *) echo "usage: devilsec-screenshot {region|window|full}"; exit 1 ;;
esac

# flameshot in 'gui' mode writes the file itself; for others we wrote OUT.
LATEST=$(ls -t "$SHOT_DIR"/*.png 2>/dev/null | head -1)

if [[ -n "$LATEST" ]]; then
    notify-send -u low -t 3000 -i "$LATEST" "DEVILSEC · screenshot" "$(basename "$LATEST")"
fi
