#!/usr/bin/env bash
# styx · DEVILSEC control panel · v1.0.4d
# Fix: printf was using single quotes which prevented variable expansion.

set -uo pipefail

STYX_VERSION="1.0.4d"
STYX_HOME="/opt/devilsec/share/styx"
STYX_STATE="$HOME/.config/devilsec"
ROFI_THEME="$HOME/.config/rofi/themes/devilsec.rasi"
mkdir -p "$STYX_STATE"

if [[ -t 1 ]]; then
    R=$'\033[0m'; B=$'\033[1m'; D=$'\033[2m'
    CRIM=$'\033[38;2;220;38;65m'
    VIO=$'\033[38;2;138;43;226m'
    GOLD=$'\033[38;2;212;175;55m'
    ASH=$'\033[38;2;120;120;140m'
else
    R="" B="" D="" CRIM="" VIO="" GOLD="" ASH=""
fi

# id|icon|label|short description|module-file (without .sh)
MENU=(
    "wall|󰸉|Wallpaper|Cycle, pick or randomise|wallpaper"
    "theme|󰉼|Colour theme|Limbo · Inferno · Purgatory|theme"
    "opacity|󰂄|Window opacity|Kitty/rofi transparency|opacity"
    "bar|󰕮|Polybar|Height, opacity, variants|polybar"
    "comp|󰍹|Compositor|Picom presets|compositor"
    "bright|󰃞|Brightness|Display brightness 1-100|brightness"
    "gamma|󰛨|Gamma|Day / night colour temperature|gamma"
    "font|󰛖|Font size|Terminal & polybar fonts|font"
    "tools|󰒓|Tools|Arsenal, pivoting, BloodHound|tools"
    "scope|󰒃|Scope manager|Add/remove target IPs|scope"
    "help|󰋽|Help|Show all keybindings & commands|help"
    "info|󰋽|About|Versions, paths, version|about"
)

run_module() {
    local mod="$1"
    local script="$STYX_HOME/${mod}.sh"
    if [[ ! -x "$script" ]]; then
        notify-send -u critical "styx" "module not found: $mod"
        return 1
    fi
    if command -v kitty &>/dev/null; then
        kitty --class=styx-module --title="styx · $mod" \
              -e bash -c "'$script'; printf '\n  ▸  press <enter> to close '; read"
    elif command -v xterm &>/dev/null; then
        xterm -class styx-module -title "styx · $mod" \
              -e bash -c "'$script'; printf '\npress enter to close '; read"
    else
        "$script"
    fi
}

banner() {
    printf "\n  ${VIO}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${R}\n"
    printf "  ${VIO}┃${R}                                                                 ${VIO}┃${R}\n"
    printf "  ${VIO}┃${R}   ${B}${CRIM}styx${R}  ${D}· DEVILSEC control panel · v${STYX_VERSION}${R}                      ${VIO}┃${R}\n"
    printf "  ${VIO}┃${R}   ${D}\"The river that everything crosses.\"${R}                       ${VIO}┃${R}\n"
    printf "  ${VIO}┃${R}                                                                 ${VIO}┃${R}\n"
    printf "  ${VIO}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${R}\n\n"
}

tui_loop() {
    while :; do
        clear
        banner
        local i=1
        for entry in "${MENU[@]}"; do
            IFS='|' read -r id icon label desc action <<<"$entry"
            # FIX: use double quotes so $VIO, $R etc. expand
            printf "   ${VIO}%2d${R}  %s  ${B}%s${R}    ${D}%s${R}\n" \
                "$i" "$icon" "$label" "$desc"
            ((i++))
        done
        printf "\n    ${VIO} 0${R}  ${CRIM}󰗼${R}  Exit\n\n"
        printf "  ${CRIM}†${R}  choose ▸ "
        IFS= read -r choice
        [[ -z "$choice" ]] && continue
        if [[ "$choice" == "0" ]]; then clear; exit 0; fi
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#MENU[@]} )); then
            entry="${MENU[$((choice-1))]}"
            IFS='|' read -r _ _ _ _ action <<<"$entry"
            local script="$STYX_HOME/${action}.sh"
            if [[ -x "$script" ]]; then
                "$script"
            else
                printf "\n  ${CRIM}✗${R}  module missing: %s\n" "$action"
            fi
            printf "\n  ${GOLD}▸${R}  press <enter> to return "
            read -r _
        else
            printf "\n  ${CRIM}!${R}  invalid\n"
            sleep 0.8
        fi
    done
}

rofi_loop() {
    local lines=()
    local -A by_label
    for entry in "${MENU[@]}"; do
        IFS='|' read -r id icon label desc action <<<"$entry"
        local key="${icon}  ${label}"
        local row="${key}    ·  ${desc}"
        lines+=("$row")
        by_label["$key"]="$action"
    done

    local theme="$ROFI_THEME"
    [[ -f "$theme" ]] || theme=""

    local choice
    choice=$(printf '%s\n' "${lines[@]}" | \
        rofi -dmenu -i -p "styx" \
             ${theme:+-theme "$theme"} \
             -no-custom -format 's' 2>/dev/null) || return 0

    [[ -z "$choice" ]] && return 0

    local key="${choice%%    ·*}"
    local action="${by_label[$key]:-}"

    if [[ -n "$action" ]]; then
        run_module "$action"
    else
        notify-send -u critical "styx" "no module matched '$choice'"
    fi
}

case "${1:-}" in
    -g|--gui)  rofi_loop ;;
    -h|--help)
        cat <<EOF
styx — DEVILSEC control panel · v$STYX_VERSION

  styx              run the interactive terminal UI
  styx -g           launch the graphical (rofi) picker — Super+Alt+S
  styx -m <module>  run a single module directly

Available modules:
$(ls "$STYX_HOME" 2>/dev/null | sed 's/\.sh$//' | sort | sed 's/^/  /')
EOF
        ;;
    -m)
        shift
        [[ -n "${1:-}" ]] && run_module "$1" || { echo "module name required" >&2; exit 1; }
        ;;
    "")
        tui_loop
        ;;
    *)
        if [[ -f "$STYX_HOME/${1}.sh" ]]; then
            run_module "$1"
        else
            echo "unknown module: $1" >&2; exit 1
        fi
        ;;
esac
