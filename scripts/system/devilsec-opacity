#!/usr/bin/env bash
# DEVILSEC opacity controller · v1.1.0 final
# Uses _NET_WM_WINDOW_OPACITY (xprop) to set client-side opacity.
# Has a 60% floor because lower values render as black in VBox without 3D.

set -uo pipefail

STATE="$HOME/.config/devilsec/opacity.state"
# Floor: empirically determined. Below 60%, xrender + VBox renders black.
MIN_OPACITY=60
DEFAULT_F=85
DEFAULT_U=75

TARGET_CLASSES_REGEX='(kitty|styx-module|rofi|dunst)'
EXCLUDE_CLASSES_REGEX='(polybar|firefox|burp|wireshark|virtualbox|desktop)'

notify() { command -v notify-send >/dev/null 2>&1 && notify-send -u low "DEVILSEC opacity" "$*" || true; }

load_state() {
    FOCUSED="$DEFAULT_F"; UNFOCUSED="$DEFAULT_U"
    if [[ -f "$STATE" ]]; then
        source "$STATE" 2>/dev/null || true
    fi
    [[ "${FOCUSED:-}" =~ ^[0-9]+$ ]] || FOCUSED="$DEFAULT_F"
    [[ "${UNFOCUSED:-}" =~ ^[0-9]+$ ]] || UNFOCUSED="$DEFAULT_U"
}

save_state() {
    mkdir -p "$(dirname "$STATE")"
    printf 'FOCUSED=%s\nUNFOCUSED=%s\n' "$FOCUSED" "$UNFOCUSED" > "$STATE"
}

clamp_pct() {
    local v="$1"
    [[ "$v" =~ ^[0-9]+$ ]] || return 1
    if (( v < MIN_OPACITY )); then
        # Tell the user we're clamping (only when called from CLI, not daemon)
        if [[ -t 1 ]]; then
            printf '[!] %s%% is below safe minimum, using %s%% (VBox xrender limit)\n' "$v" "$MIN_OPACITY" >&2
        fi
        v=$MIN_OPACITY
    fi
    (( v > 100 )) && v=100
    printf '%s\n' "$v"
}

pct_to_opacity_hex() {
    local pct="$1"
    python3 - "$pct" <<'PY'
import sys
pct = int(sys.argv[1])
value = round(0xffffffff * pct / 100)
print(f"0x{value:08x}")
PY
}

window_class_lc() {
    local wid="$1"
    xprop -id "$wid" WM_CLASS 2>/dev/null | tr '[:upper:]' '[:lower:]'
}

window_type_lc() {
    local wid="$1"
    xprop -id "$wid" _NET_WM_WINDOW_TYPE 2>/dev/null | tr '[:upper:]' '[:lower:]'
}

is_target_window() {
    local wid="$1" class type
    class="$(window_class_lc "$wid")"
    type="$(window_type_lc "$wid")"
    [[ "$type" =~ (_net_wm_window_type_dock|_net_wm_window_type_desktop) ]] && return 1
    [[ "$class" =~ $EXCLUDE_CLASSES_REGEX ]] && return 1
    [[ "$class" =~ $TARGET_CLASSES_REGEX ]] && return 0
    return 1
}

all_windows() {
    if command -v bspc >/dev/null 2>&1; then
        bspc query -N -n .window 2>/dev/null || true
    elif command -v xdotool >/dev/null 2>&1; then
        xdotool search --onlyvisible --name '.*' 2>/dev/null || true
    fi
}

focused_window() {
    if command -v bspc >/dev/null 2>&1; then
        bspc query -N -n focused 2>/dev/null || true
    elif command -v xdotool >/dev/null 2>&1; then
        xdotool getactivewindow 2>/dev/null || true
    fi
}

ensure_picom() {
    pgrep -x picom >/dev/null 2>&1 && return 0
    if command -v picom >/dev/null 2>&1; then
        nohup picom --config "$HOME/.config/picom/picom.conf" --daemon >/tmp/picom.log 2>&1 &
        disown 2>/dev/null || true
        sleep 0.5
    fi
}

apply_opacity() {
    command -v xprop >/dev/null 2>&1 || { echo "xprop is required" >&2; return 1; }
    load_state
    ensure_picom || true

    local active fhex uhex wid hex count=0
    active="$(focused_window)"
    fhex="$(pct_to_opacity_hex "$FOCUSED")"
    uhex="$(pct_to_opacity_hex "$UNFOCUSED")"

    while IFS= read -r wid; do
        [[ -n "$wid" ]] || continue
        is_target_window "$wid" || continue
        if [[ "$wid" == "$active" ]]; then
            hex="$fhex"
        else
            hex="$uhex"
        fi
        xprop -id "$wid" -f _NET_WM_WINDOW_OPACITY 32c \
            -set _NET_WM_WINDOW_OPACITY "$hex" >/dev/null 2>&1 || true
        count=$((count + 1))
    done < <(all_windows)

    printf '[ok] opacity → focused=%s%% unfocused=%s%% (%s windows)\n' \
        "$FOCUSED" "$UNFOCUSED" "$count"
}

reset_opacity() {
    command -v xprop >/dev/null 2>&1 || return 1
    local wid count=0
    while IFS= read -r wid; do
        [[ -n "$wid" ]] || continue
        xprop -id "$wid" -remove _NET_WM_WINDOW_OPACITY >/dev/null 2>&1 || true
        count=$((count + 1))
    done < <(all_windows)
    printf '[ok] removed client opacity from %s windows\n' "$count"
}

run_daemon() {
    command -v bspc >/dev/null 2>&1 || { echo "bspc is required for daemon mode" >&2; exit 1; }
    apply_opacity >/dev/null 2>&1 || true
    bspc subscribe node_add node_remove node_focus desktop_focus 2>/dev/null | while read -r _; do
        sleep 0.05
        apply_opacity >/dev/null 2>&1 || true
    done
}

case "${1:-show}" in
    show)
        load_state
        printf 'focused=%s%% unfocused=%s%% (min allowed: %s%%)\n' \
            "$FOCUSED" "$UNFOCUSED" "$MIN_OPACITY"
        ;;
    apply)
        apply_opacity
        ;;
    reset)
        reset_opacity
        ;;
    daemon)
        run_daemon
        ;;
    *)
        if [[ "$1" =~ ^[0-9]+$ ]]; then
            FOCUSED="$(clamp_pct "$1")" || { echo "focused must be numeric" >&2; exit 1; }
            UNFOCUSED="$(clamp_pct "${2:-$(( FOCUSED > 10 ? FOCUSED - 10 : FOCUSED ))}")" || { echo "unfocused must be numeric" >&2; exit 1; }
            save_state
            apply_opacity
            notify "focused=${FOCUSED}% · unfocused=${UNFOCUSED}%"
        else
            cat <<HELP
Usage:
  devilsec-opacity show
  devilsec-opacity <focused%> [unfocused%]   (clamped to ${MIN_OPACITY}-100)
  devilsec-opacity apply
  devilsec-opacity reset
  devilsec-opacity daemon
HELP
            exit 1
        fi
        ;;
esac
