#!/usr/bin/env bash
# devilsec-picom-watchdog
# Monitors picom and restarts it if it dies. Uses exponential backoff to avoid
# crash loops. Sleeps quietly when picom is healthy.
#
# Lifetime: tied to the X session — exits if DISPLAY is no longer valid.
# Spawn from bspwmrc after picom is started.

set -uo pipefail

LOG="/tmp/devilsec-picom-watchdog.log"
CONF="$HOME/.config/picom/picom.conf"
MAX_FAILURES=5
COOLDOWN=2          # seconds between failure resets

log() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >> "$LOG"; }

# Track failures within a time window. Reset after a stable period.
failures=0
last_fail=0

log "watchdog started · pid=$$"

while :; do
    # If X is gone, exit. We're done.
    if ! xset q &>/dev/null; then
        log "X session terminated — watchdog exiting"
        exit 0
    fi

    if pgrep -x picom >/dev/null 2>&1; then
        # picom is alive. Reset failure counter if it's been stable for a while.
        now=$(date +%s)
        if (( now - last_fail > 60 )); then
            failures=0
        fi
        sleep 5
        continue
    fi

    # picom is dead. Reanimate.
    now=$(date +%s)
    if (( failures >= MAX_FAILURES )); then
        log "picom died ${failures} times in a row — giving up"
        notify-send -u critical "DEVILSEC" "picom keeps crashing. Run 'styx -m compositor' or check /tmp/picom.log" 2>/dev/null || true
        # Sleep a long time before retrying, in case the user fixes it
        sleep 300
        failures=0
        continue
    fi

    failures=$((failures + 1))
    last_fail=$now
    log "picom is dead (failure #$failures) — restarting in ${COOLDOWN}s"
    sleep "$COOLDOWN"

    # Make sure no zombie compositor holds the X selection
    for proc in xcompmgr compton; do
        pkill -9 -x "$proc" 2>/dev/null || true
    done

    # Launch picom detached
    if [[ -f "$CONF" ]]; then
        nohup picom --config "$CONF" --daemon &>/tmp/picom.log &
    else
        nohup picom --daemon &>/tmp/picom.log &
    fi
    disown 2>/dev/null || true
    sleep 1
done
