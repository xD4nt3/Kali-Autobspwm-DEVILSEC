#!/usr/bin/env bash
# DEVILSEC keyboard layout switcher · v1.0.4g
# Instant X11 layout switch between English US and Latin American with dead tilde.

set -uo pipefail

STATE="$HOME/.config/devilsec/keyboard.state"
ROFI_THEME="$HOME/.config/rofi/themes/devilsec.rasi"

notify() { command -v notify-send >/dev/null 2>&1 && notify-send -u low "DEVILSEC keyboard" "$*" || true; }

apply_layout() {
    local layout="$1" variant="${2:-}"
    if ! command -v setxkbmap >/dev/null 2>&1; then
        echo "setxkbmap is not installed. Try: sudo apt install x11-xkb-utils" >&2
        exit 1
    fi
    if [[ -n "$variant" ]]; then
        setxkbmap -layout "$layout" -variant "$variant"
    else
        setxkbmap -layout "$layout"
    fi
    mkdir -p "$(dirname "$STATE")"
    printf 'LAYOUT=%s\nVARIANT=%s\n' "$layout" "$variant" > "$STATE"
    notify "Layout aplicado: ${layout}${variant:+ ($variant)}"
    echo "[ok] keyboard layout → ${layout}${variant:+ ($variant)}"
}

current_layout() {
    if command -v setxkbmap >/dev/null 2>&1; then
        setxkbmap -query 2>/dev/null | sed 's/^/  /'
    fi
}

choose() {
    local prompt="keyboard" choice
    if command -v rofi >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
        if [[ -f "$ROFI_THEME" ]]; then
            choice=$(printf 'us|English US\nlatam-deadtilde|Latinoamérica (dead tilde)\nshow|Ver layout actual\n' \
                | rofi -dmenu -sep '|' -p "$prompt" -theme "$ROFI_THEME")
        else
            choice=$(printf 'us|English US\nlatam-deadtilde|Latinoamérica (dead tilde)\nshow|Ver layout actual\n' \
                | rofi -dmenu -sep '|' -p "$prompt")
        fi
    else
        cat <<MENU
DEVILSEC · keyboard layout
  1) English US
  2) Latinoamérica (dead tilde)
  3) Ver layout actual
MENU
        printf 'choose > '
        read -r ans
        case "$ans" in
            1) choice="us" ;;
            2) choice="latam-deadtilde" ;;
            3) choice="show" ;;
            *) choice="" ;;
        esac
    fi
    case "$choice" in
        us|"English US") apply_layout us ;;
        latam-deadtilde|"Latinoamérica (dead tilde)") apply_layout latam deadtilde ;;
        show|"Ver layout actual") current_layout ;;
        *) exit 0 ;;
    esac
}

case "${1:-menu}" in
    menu|"") choose ;;
    us|en|english) apply_layout us ;;
    latam|latin|es|es-latam|deadtilde) apply_layout latam deadtilde ;;
    show|status) current_layout ;;
    *)
        cat <<HELP
Usage:
  devilsec-keyboard              # menu
  devilsec-keyboard us           # English US
  devilsec-keyboard latam        # Latin America, dead tilde
  devilsec-keyboard show         # current layout
HELP
        exit 1
        ;;
esac
