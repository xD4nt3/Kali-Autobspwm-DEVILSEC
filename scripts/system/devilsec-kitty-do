#!/usr/bin/env bash
# DEVILSEC kitty controller · v1.0.4g
# Focused-kitty first, no Super+Alt+Arrow conflicts with bspwm resizing.
# Actions: new_tab, close_tab, next_tab, previous_tab, rename_tab, move_tab_forward,
# move_tab_backward, list

set -uo pipefail

action="${1:-help}"

notify() {
    command -v notify-send >/dev/null 2>&1 && notify-send -u low "DEVILSEC kitty" "$*" || true
}

need_xdotool() {
    command -v xdotool >/dev/null 2>&1 || {
        notify "xdotool no está instalado. Instala: sudo apt install xdotool"
        return 1
    }
}

active_window_id() {
    need_xdotool || return 1
    xdotool getactivewindow 2>/dev/null
}

active_is_kitty() {
    need_xdotool || return 1
    local wid pid cls name comm args
    wid="$(active_window_id)" || return 1
    cls="$(xdotool getwindowclassname "$wid" 2>/dev/null || true)"
    name="$(xdotool getwindowname "$wid" 2>/dev/null || true)"
    pid="$(xdotool getwindowpid "$wid" 2>/dev/null || true)"
    comm=""; args=""
    [[ -n "$pid" ]] && comm="$(ps -p "$pid" -o comm= 2>/dev/null || true)"
    [[ -n "$pid" ]] && args="$(ps -p "$pid" -o args= 2>/dev/null || true)"

    [[ "$cls"  =~ ([Kk]itty|styx-module) ]] && return 0
    [[ "$name" =~ ([Kk]itty|styx) ]] && return 0
    [[ "$comm" =~ ([Kk]itty) ]] && return 0
    [[ "$args" =~ ([Kk]itty) ]] && return 0
    return 1
}

release_modifiers() {
    need_xdotool || return 1
    xdotool keyup Super_L Super_R Alt_L Alt_R Shift_L Shift_R Control_L Control_R \
        >/dev/null 2>&1 || true
}

send_key_to_focused_kitty() {
    local key="$1"
    need_xdotool || return 1
    active_is_kitty || return 1
    release_modifiers
    sleep 0.04
    xdotool key --clearmodifiers "$key" >/dev/null 2>&1
}

case "$action" in
    new_tab)
        if send_key_to_focused_kitty 'ctrl+shift+t'; then exit 0; fi
        # If there is no focused kitty, opening a new one is sane.
        command -v kitty >/dev/null 2>&1 && { kitty >/dev/null 2>&1 & disown; exit 0; }
        notify "kitty no está instalado"
        exit 1
        ;;
    close_tab)
        send_key_to_focused_kitty 'ctrl+shift+w' || send_key_to_focused_kitty 'ctrl+shift+q' || {
            notify "Enfoca una ventana kitty para cerrar su pestaña"; exit 1;
        }
        ;;
    next_tab)
        send_key_to_focused_kitty 'ctrl+shift+Right' || {
            notify "Enfoca una ventana kitty para moverte de pestaña"; exit 1;
        }
        ;;
    previous_tab|prev_tab)
        send_key_to_focused_kitty 'ctrl+shift+Left' || {
            notify "Enfoca una ventana kitty para moverte de pestaña"; exit 1;
        }
        ;;
    rename_tab)
        # Native kitty action: set_tab_title opens kitty's own rename prompt.
        send_key_to_focused_kitty 'ctrl+shift+alt+t' || {
            notify "Enfoca una ventana kitty para renombrar la pestaña"; exit 1;
        }
        ;;
    move_tab_forward)
        send_key_to_focused_kitty 'ctrl+shift+period' || {
            notify "Enfoca una ventana kitty para mover la pestaña"; exit 1;
        }
        ;;
    move_tab_backward)
        send_key_to_focused_kitty 'ctrl+shift+comma' || {
            notify "Enfoca una ventana kitty para mover la pestaña"; exit 1;
        }
        ;;
    list|help|*)
        cat <<HELP
DEVILSEC kitty tabs:
  devilsec-kitty-do new_tab
  devilsec-kitty-do close_tab
  devilsec-kitty-do next_tab
  devilsec-kitty-do previous_tab
  devilsec-kitty-do rename_tab
  devilsec-kitty-do move_tab_forward
  devilsec-kitty-do move_tab_backward
HELP
        ;;
esac
