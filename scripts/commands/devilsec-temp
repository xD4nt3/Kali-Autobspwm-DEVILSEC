#!/usr/bin/env bash
# devilsec-temp {toggle|up|down|set <kelvin>}
set -uo pipefail

STATE="$HOME/.config/devilsec/temp.state"
mkdir -p "$(dirname "$STATE")"
current=$(cat "$STATE" 2>/dev/null || echo 6500)
enabled=$(cat "${STATE}.on" 2>/dev/null || echo 1)

case "${1:-toggle}" in
    toggle)
        if [[ "$enabled" == "1" ]]; then
            redshift -x &>/dev/null
            echo 0 > "${STATE}.on"
            notify-send -u low "temp" "off"
        else
            redshift -O "$current" &>/dev/null
            echo 1 > "${STATE}.on"
            notify-send -u low "temp" "${current}K"
        fi
        ;;
    up)
        new=$(( current + 250 )); (( new > 6500 )) && new=6500
        redshift -O "$new" &>/dev/null
        echo "$new" > "$STATE"; echo 1 > "${STATE}.on"
        notify-send -u low "temp" "${new}K"
        ;;
    down)
        new=$(( current - 250 )); (( new < 2500 )) && new=2500
        redshift -O "$new" &>/dev/null
        echo "$new" > "$STATE"; echo 1 > "${STATE}.on"
        notify-send -u low "temp" "${new}K"
        ;;
    set)
        new="${2:-6500}"
        [[ "$new" =~ ^[0-9]+$ ]] || { echo "bad kelvin"; exit 1; }
        redshift -O "$new" &>/dev/null
        echo "$new" > "$STATE"; echo 1 > "${STATE}.on"
        ;;
esac
