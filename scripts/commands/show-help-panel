#!/usr/bin/env bash
# show-help-panel — DEVILSEC keybindings & commands cheat-sheet
set -uo pipefail

if [[ -t 1 ]]; then
    R=$'\033[0m'; B=$'\033[1m'; D=$'\033[2m'
    VIO=$'\033[38;2;138;43;226m'
    CRIM=$'\033[38;2;220;38;65m'
    GOLD=$'\033[38;2;212;175;55m'
    ASH=$'\033[38;2;120;120;140m'
    GREEN=$'\033[38;2;127;176;105m'
else
    R="" B="" D="" VIO="" CRIM="" GOLD="" ASH="" GREEN=""
fi

# helper
h() { printf "\n  ${B}${VIO}┃ %s${R}\n  ${VIO}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n" "$*"; }
k() { printf "    ${GOLD}%-32s${R}  ${ASH}%s${R}\n" "$1" "$2"; }

cat <<EOF

  ${B}${CRIM}▓ DEVILSEC · keybindings & commands${R}
  ${D}Press q to quit · /search to filter · arrows or j/k to scroll${R}
EOF

h "bspwm"
k "Win + 1..9 / 0"             "switch to workspace"
k "Win + Shift + 1..9 / 0"     "send window to workspace"
k "Win + Alt + 1..9 / 0"       "send window and follow"
k "Win + Shift + R"            "reload bspwm"
k "Win + Shift + Q"            "log out of bspwm"

h "Preselectors"
k "Ctrl+Win+Alt + arrows"      "activate preselector"
k "Ctrl+Win+Alt + 1..9"        "set preselector ratio"
k "Ctrl+Win+Alt + Space"       "cancel preselection"

h "sxhkd"
k "Win + Esc"                  "reload sxhkd"

h "Polybar / IP helpers"
k "Win + Shift + F1"           "copy local IP"
k "Win + Shift + F2"           "copy VPN IP"
k "Win + Shift + F3"           "copy target IP"

h "Brightness / Volume / Temperature"
k "Win/Fn + F2 / F3"           "brightness down / up"
k "Win/Fn + F5"                "toggle mute"
k "Win/Fn + F6 / F7"           "volume down / up"
k "Win/Fn + F8"                "toggle colour temperature"
k "Win/Fn + F9 / F10"          "temperature down / up"

h "Rofi"
k "Win + Shift + D"            "open rofi launcher"
k "Win + Shift + P"            "open power menu"
k "Win + Shift + S"            "open scope manager"
k "Win + Alt + S"              "open styx (control panel)"

h "Window management"
k "Win + Alt + arrows"         "expand window"
k "Win + Alt + Shift + arrows" "contract window"
k "Win + W"                    "close current window"
k "Win + S"                    "toggle floating"
k "Win + Right click"          "resize floating windows"
k "Win + Left click"           "move floating window"
k "Win + T"                    "back to tiled (terminal mode)"
k "Win + M"                    "full mode (keeps polybar)"
k "Win + F"                    "fullscreen (covers polybar)"
k "Win + arrows"               "navigate windows"

h "Terminal (kitty)"
k "Win + Enter"                "open kitty"
k "Ctrl+Shift+T"               "new tab"
k "Ctrl+Shift+arrows"          "navigate tabs"
k "Ctrl+Shift+Alt+T"           "rename tab"
k "Ctrl+Shift +/-"             "font size up/down"
k "Ctrl+Shift+Backspace"       "reset font size"
k "Ctrl+Shift+Enter"           "split (sub-terminal)"
k "Ctrl+Shift+R"               "kitty resize mode"
k "Ctrl+Shift+Z"               "zoom sub-terminal"
k "F1 / F2"                    "copy / paste · clipboard 1"
k "F3 / F4"                    "copy / paste · clipboard 2"

h "Applications"
k "Win + Shift + A"            "Postman"
k "Win + Shift + O"            "Obsidian"
k "Win + Shift + E"            "PyCharm"
k "Win + Shift + F"            "Firefox"
k "Win + Shift + B"            "Burp Suite"
k "Win + Shift + V"            "VS Code"
k "Win + Shift + G"            "Thunar"
k "PrintScreen"                "flameshot"

h "DEVILSEC commands"
k "styx"                       "interactive control panel (TUI)"
k "styx -g"                    "control panel (rofi GUI)"
k "show-help-panel"            "this view"
k "set-wallpaper [path]"       "rofi picker or direct apply"
k "devilsec-arsenal"           "categorised tool catalogue"
k "devilsec-arsenal pivoting"  "pivoting category (ligolo, chisel)"
k "ligolo proxy [port]"        "start ligolo proxy"
k "bloodhound-ce up|down|..."  "BloodHound CE controller"
k "wlfind <kw>"                "fuzzy search wordlists"
k "mkt <name>"                 "create CTF workspace folder"
k "xcopy <file>"               "file → clipboard"
k "extract-ports <gnmap>"      "extract open ports from nmap"
k "add-asset-to-scope <a>"     "scope mgmt"
k "remove-asset-from-scope <a>" "scope mgmt"
k "kali-optimus"               "repo repair + full upgrade"
k "switch-java-version"        "change default java"
k "enable-touchpad"            "(laptops)"
k "disable-touchpad"           "(laptops)"
k "clearHistory"               "wipe in-memory zsh history"
k "removeHistory"              "delete ~/.zsh_history"

h "Network (nmcli helpers)"
k "nmcli-connect-device"       "connect wifi (interactive ok)"
k "nmcli-disconnect-device"    ""
k "nmcli-list-active-connections" ""
k "nmcli-list-all-connections" ""
k "nmcli-list-devices"         ""
k "nmcli-scan-wifi"            "rescan"
k "nmcli-wifi-info"            "current creds + QR"
k "nmcli-wifi-on / -off"       ""
k "nmcli-wwan-on / -off"       "mobile broadband"
k "nmcli-create-hotspot"       "hotspot"
k "nmcli-delete-connection"    ""
k "nmcli-up-connection"        ""
k "nmcli-down-connection"      ""
k "nmcli-restart-networking"   "restart NetworkManager"

echo
