#!/usr/bin/env bash
# xcopy <file-or-stdin> → system clipboard
set -uo pipefail
if [[ -n "${1:-}" && -f "$1" ]]; then
    src="cat -- '$1'"
else
    src="cat"
fi
if command -v xclip &>/dev/null; then
    eval "$src" | xclip -selection clipboard
elif command -v xsel &>/dev/null; then
    eval "$src" | xsel --clipboard
elif command -v wl-copy &>/dev/null; then
    eval "$src" | wl-copy
else
    echo "no clipboard tool available (install xclip, xsel, or wl-clipboard)" >&2
    exit 1
fi
[[ -n "${1:-}" ]] && echo "copied: $1" >&2 || echo "copied from stdin" >&2
