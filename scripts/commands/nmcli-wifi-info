#!/usr/bin/env bash
# Show current wifi creds + QR code
ssid=$(nmcli -t -f active,ssid device wifi | grep '^yes' | cut -d: -f2 | head -1)
[[ -z "$ssid" ]] && { echo "not connected to wifi"; exit 1; }
pass=$(sudo grep -oP 'psk=\K.*' "/etc/NetworkManager/system-connections/${ssid}.nmconnection" 2>/dev/null | head -1)
echo "SSID: $ssid"
echo "PASS: ${pass:-(unknown)}"
if [[ -n "$pass" ]] && command -v qrencode &>/dev/null; then
    qrencode -t ANSIUTF8 "WIFI:T:WPA;S:${ssid};P:${pass};;"
fi
