#!/usr/bin/env bash
# extract-ports <nmap-grepable-file>
# Extracts open ports from nmap -oG output, copies to clipboard, prints summary.
set -uo pipefail
file="${1:?usage: extract-ports <nmap.gnmap>}"
[[ -f "$file" ]] || { echo "no such file: $file" >&2; exit 1; }

ports=$(grep -oP '\d+/open' "$file" | awk -F/ '{print $1}' | sort -nu | paste -sd, -)
ips=$(grep -oP '(?<=Host: )[\d.]+' "$file" | sort -u | paste -sd, -)

if [[ -z "$ports" ]]; then
    echo "no open ports found in $file" >&2; exit 1
fi

cat <<OUT
[*] Hosts:  $ips
[*] Ports:  $ports
OUT

# Copy ports only (most common use case for follow-up scans)
printf '%s' "$ports" | xcopy 2>/dev/null
echo "[*] Ports copied to clipboard"
