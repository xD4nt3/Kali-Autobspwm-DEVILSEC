alias urldecode='python3 -c "import sys,urllib.parse as u;print(u.unquote_plus(sys.argv[1]))"'
alias b64='base64 -w0'
alias b64d='base64 -d'

# git
alias g='git'
alias gst='git status -sb'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate -20'
alias gco='git checkout'
alias gp='git pull'

# common
alias grep='grep --color=auto'
alias diff='diff --color=auto'
alias ip='ip --color=auto'
alias mv='mv -i'
alias cp='cp -i'
alias rm='rm -I'
alias mkdir='mkdir -p'
alias df='df -h'
alias du='du -h'
alias free='free -h'
alias ports='ss -tulnp'

# ─── Functions ──────────────────────────────────────────────────────────────
mkcd() { mkdir -p "$1" && cd "$1" || return 1; }

extract() {
    [[ -f "$1" ]] || { echo "extract: '$1' not found"; return 1; }
    case "$1" in
        *.tar.bz2|*.tbz2) tar xjf "$1" ;;
        *.tar.gz|*.tgz)   tar xzf "$1" ;;
        *.tar.xz|*.txz)   tar xJf "$1" ;;
        *.tar.zst)        tar --zstd -xf "$1" ;;
        *.tar)            tar xf "$1" ;;
        *.bz2)            bunzip2 "$1" ;;
        *.gz)             gunzip "$1" ;;
        *.zip)            unzip "$1" ;;
        *.rar)            unrar x "$1" ;;
        *.7z)             7z x "$1" ;;
        *.xz)             unxz "$1" ;;
        *)                echo "extract: unknown format: '$1'"; return 1 ;;
    esac
}

# ─── Greeter (ONLY the first terminal of the X session) ─────────────────────
__devilsec_greeter() {
    local marker="/tmp/devilsec-greeted-${DISPLAY:-na}-${USER}"
    [[ $- == *i* && -t 1 ]] || return 0

    # Compare marker against X session start time
    if [[ -e "$marker" ]]; then
        local xsession_start marker_time
        xsession_start=$(stat -c %Y /tmp/.X*-lock 2>/dev/null | sort -n | head -1)
        marker_time=$(stat -c %Y "$marker" 2>/dev/null)
        if [[ -n "$xsession_start" && -n "$marker_time" ]] \
           && (( marker_time >= xsession_start )); then
            return 0
        fi
    fi

    touch "$marker"
    command -v fastfetch &>/dev/null && timeout 2 fastfetch 2>/dev/null || true
}
__devilsec_greeter
unset -f __devilsec_greeter

# ─── Prompt (starship) ──────────────────────────────────────────────────────
if command -v starship &>/dev/null; then
    eval "$(starship init zsh)"
fi
