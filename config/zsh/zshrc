# ─── Environment ─────────────────────────────────────────────────────────────
export EDITOR=nvim
export VISUAL=nvim
export PAGER=less
export LESS='-R --use-color -Dd+r -Du+b'

export DEVILSEC_HOME=/opt/devilsec
case ":$PATH:" in
    *":$DEVILSEC_HOME/bin:"*) ;;
    *) export PATH="$DEVILSEC_HOME/bin:$PATH" ;;
esac
case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

# ─── History ─────────────────────────────────────────────────────────────────
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS
setopt SHARE_HISTORY APPEND_HISTORY INC_APPEND_HISTORY

# ─── Behaviour ───────────────────────────────────────────────────────────────
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS PUSHD_SILENT
setopt EXTENDED_GLOB GLOB_DOTS NO_BEEP NOTIFY
setopt INTERACTIVE_COMMENTS

bindkey -e
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward
bindkey '^R' history-incremental-search-backward

autoload -Uz compinit && compinit -d "$HOME/.zcompdump-$ZSH_VERSION"

# ─── Plugins ─────────────────────────────────────────────────────────────────
ZSH_PLUGIN_DIR="$HOME/.zsh-plugins"
[[ -d "$ZSH_PLUGIN_DIR/zsh-completions/src" ]] && \
    fpath=("$ZSH_PLUGIN_DIR/zsh-completions/src" $fpath)
[[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
    source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[[ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
    source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
[[ -f "$ZSH_PLUGIN_DIR/fzf-tab/fzf-tab.plugin.zsh" ]] && \
    source "$ZSH_PLUGIN_DIR/fzf-tab/fzf-tab.plugin.zsh"
[[ -f "$ZSH_PLUGIN_DIR/zsh-history-substring-search/zsh-history-substring-search.zsh" ]] && \
    source "$ZSH_PLUGIN_DIR/zsh-history-substring-search/zsh-history-substring-search.zsh"

ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#807a90,italic"

# fzf
[[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[[ -f /usr/share/doc/fzf/examples/completion.zsh ]] && source /usr/share/doc/fzf/examples/completion.zsh
export FZF_DEFAULT_OPTS=" \
    --color=bg+:#16121C,bg:-1,spinner:#DC2641,hl:#8A2BE2 \
    --color=fg:#E8E3F2,header:#8A2BE2,info:#807a90,pointer:#DC2641 \
    --color=marker:#D4AF37,fg+:#E8E3F2,prompt:#DC2641,hl+:#8A2BE2 \
    --color=border:#8A2BE2 \
    --border=rounded \
    --height=40% --layout=reverse"

# zoxide
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init zsh --cmd j)"
fi

# ─── bat / batcat compatibility (Kali names it batcat) ──────────────────────
if command -v bat &>/dev/null; then
    alias cat='bat --style=plain --paging=never'
elif command -v batcat &>/dev/null; then
    alias cat='batcat --style=plain --paging=never'
    [[ ! -e "$HOME/.local/bin/bat" ]] && mkdir -p "$HOME/.local/bin" && \
        ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
fi

# ─── ls / lsd ───────────────────────────────────────────────────────────────
if command -v lsd &>/dev/null; then
    alias ls='lsd --group-directories-first'
    alias ll='lsd -lh --group-directories-first'
    alias la='lsd -lha --group-directories-first'
    alias lt='lsd --tree --depth 2'
else
    alias ll='ls -lh --color=auto'
    alias la='ls -lha --color=auto'
fi

# ─── DEVILSEC ───────────────────────────────────────────────────────────────
alias arsenal='devilsec-arsenal'
alias pivoting='devilsec-arsenal pivoting'
alias adtools='devilsec-arsenal active-directory'
alias kb='devilsec-keyboard'
alias teclado='devilsec-keyboard'

# ─── pentest helpers ────────────────────────────────────────────────────────
alias myip='ip -4 addr show | grep -oP "(?<=inet\s)\d+(\.\d+){3}" | grep -v 127.0.0.1 | head -1'
alias tunip='ip -4 addr show tun0 2>/dev/null | grep -oP "(?<=inet\s)\d+(\.\d+){3}"'
